# USO: cp .env.example .env → rellenar .env → .env está en .gitignore, nunca lo commitees.

  SPRING_PROFILES_ACTIVE=dev

  # Base de datos (en dev tienen defaults en application.yml)
  DB_HOST=localhost
  DB_PORT=5432
  DB_NAME=oposites
  DB_USER=oposites
  DB_PASSWORD=CHANGE_ME

  # JWT — generar con: openssl rand -base64 32
  JWT_SECRET=CHANGE_ME

  # Google OAuth2 — https://console.cloud.google.com
  GOOGLE_CLIENT_ID=CHANGE_ME.apps.googleusercontent.com
  GOOGLE_CLIENT_SECRET=CHANGE_ME

  # Gemini IA — https://aistudio.google.com
  GEMINI_API_KEY=CHANGE_ME

  # CORS (prod)
  CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4200